# Copy to .env and edit.
#   cp .env.example .env

# --- run_miner.sh (wallet / agent) — set in .env, NOT on the CLI ---
# WALLET_NAME=matt
# HOTKEY_NAME=matt-1
# PM2_NAME=miner-1
# AXON_PORT=8091
# AGENT_PATH=/root/BT-taos-im/agents
# AGENT_NAME=MeanReversionAgent
# Required: miner.py crashes if --agent.params is empty
# AGENT_PARAMS=lazy_load=0
#
# Fleet: copy per-miner overrides to .env.miner-1, .env.miner-2, etc.
# ./run_miner.sh -P miner-1  loads .env then .env.miner-1
