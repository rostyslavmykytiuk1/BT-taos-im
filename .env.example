# Copy to .env and edit (both run_miner.sh and ./dashboard/start.sh read this file).
#   cp .env.example .env

# --- Miner telemetry (written by the agent process) ---
# Default when unset: TAOS_TELEMETRY_ENABLED=1 (on)
TAOS_TELEMETRY_ENABLED=1
TAOS_TELEMETRY_ROOT=$HOME/.taos/telemetry
# Path to agents/data (orders.csv, trades.csv for dashboard Trades tab)
TAOS_DATA_ROOT=/root/sn-79/agents/data
# Optional: only log specific books, e.g. TAOS_TELEMETRY_SAMPLE_BOOKS=0,1,2

# --- Local dashboard (./dashboard/start.sh) ---
# Default when unset: TAOS_DASHBOARD_HOST=127.0.0.1 (localhost only)
# Use 0.0.0.0 to open http://<server-ip>:8787/ (lock down firewall first)
TAOS_DASHBOARD_HOST=0.0.0.0
TAOS_DASHBOARD_PORT=8787

# --- run_miner.sh (wallet / agent) — examples only ---
# WALLET_NAME=sn79
# HOTKEY_NAME=sn79-1
# PM2_NAME=miner-1
# AGENT_PATH=/root/sn-79/agents
# AGENT_NAME=QuantTradingAgent
# AGENT_PARAMS=quote_notional=1800
