# Per-miner overlay for ./run_miner.sh -P miner-26
# 2026-06-25: V4 with SLEEP ON (no_sleep=0) + NO-CUT (max_gross_sl_bps=12). A/B the sleep toggle
# in the current fee-adverse regime vs no-sleep uid192. AGENT_PARAMS is space-separated + quoted.
WALLET_NAME=sn79
HOTKEY_NAME=sn79-26
PM2_NAME=miner-26
AXON_PORT=8116
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=AdaptiveRouterAgent
AGENT_PARAMS=lazy_load=1   # 2026-06-27 V3 A/B (revert: AGENT_NAME=TakerScalperAgent)
