# Per-miner overlay for ./run_miner.sh -P miner-30
# PureMakerV2Agent (TREATMENT): all-book maker, HOLD-FOR-REVERSION exit
# (far 50-60bps catastrophe stop, 450s giveup, 15bps TP). A/B vs miner-29 = PureMakerV1Agent (tight cut).
WALLET_NAME=sn79
HOTKEY_NAME=sn79-30
PM2_NAME=miner-30
AXON_PORT=8120
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=PureMakerV2Agent
AGENT_PARAMS=lazy_load=1
