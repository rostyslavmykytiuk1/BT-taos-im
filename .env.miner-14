# Per-miner overlay for ./run_miner.sh -P miner-14
# 2026-06-25: reverted V2->V1. The no-idle A/B arm was the worst (39% win, realPnL -11181, neg kappa);
# V2 code removed. Now a standard AdaptiveRouter (V1) control, matching the rest of the AR v1 fleet.
WALLET_NAME=sn79
HOTKEY_NAME=sn79-14
PM2_NAME=miner-14
AXON_PORT=8104
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=AdaptiveRouterAgent
AGENT_PARAMS=lazy_load=1
