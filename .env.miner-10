# Per-miner overlay for ./run_miner.sh -P miner-10
# 2026-06-25: reverted V2->V1. The AR v2 A/B lost decisively (maker win-rate 76%->37%); V2 code removed.
# Now a standard AdaptiveRouter (V1) control, matching the rest of the AR v1 fleet.
WALLET_NAME=sn79
HOTKEY_NAME=sn79-10
PM2_NAME=miner-10
AXON_PORT=8100
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=AdaptiveRouterAgent
AGENT_PARAMS=lazy_load=1
