# Per-miner overlay for ./run_miner.sh -P miner-10
# 2026-06-25: A/B arm — AdaptiveRouterV2 IDLE-ON (default), the improved-idle control (idle-cap +
# fast-reengage + lowered taker gate). Only variable vs miner-14 is allow_idle, to isolate idle-vs-no-idle.
# REVERT: AGENT_NAME=AdaptiveRouterAgent AGENT_PARAMS=lazy_load=0.
WALLET_NAME=sn79
HOTKEY_NAME=sn79-10
PM2_NAME=miner-10
AXON_PORT=8100
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=AdaptiveRouterV2Agent
AGENT_PARAMS=lazy_load=1
