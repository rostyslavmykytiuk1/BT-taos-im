# Per-miner overlay for ./run_miner.sh -P miner-12
# PureMakerAgent: canonical all-book TIGHT-CUT maker (vol-band 10-14bps stop, 150s giveup, breakeven-walk,
# 1.5-lot cap, tick/2 repeg; idle flat books). Consolidated from the V1/V4 line (V1 == V4-final config).
WALLET_NAME=sn79
HOTKEY_NAME=sn79-12
PM2_NAME=miner-12
AXON_PORT=8102
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=PureMakerAgent
AGENT_PARAMS=lazy_load=1
