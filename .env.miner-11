# Per-miner overlay for ./run_miner.sh -P miner-11
# 2026-06-25: agent renamed TakerScalperV4Agent -> TakerScalperAgent (final). Default SL now 4bps
# (was 12 no-cut). To keep miner-11 as the NO-CUT arm on next restart, add: max_gross_sl_bps=12.0
WALLET_NAME=sn79
HOTKEY_NAME=sn79-11
PM2_NAME=miner-11
AXON_PORT=8101
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=TakerScalperAgent
AGENT_PARAMS=lazy_load=1
