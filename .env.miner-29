# Per-miner overlay for ./run_miner.sh -P miner-29
# PureMakerV1Agent (CONTROL): all-book maker, tight cut (10-14bps stop, 150s giveup, 8bps TP).
# A/B baseline vs miner-30 = PureMakerV2Agent (far 50-60bps stop + 15bps TP, hold-for-reversion).
# NOTE: already running this code since ~04:39 UTC; do NOT restart (preserves cold-start clock).
WALLET_NAME=sn79
HOTKEY_NAME=sn79-29
PM2_NAME=miner-29
AXON_PORT=8119
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=PureMakerV1Agent
AGENT_PARAMS=lazy_load=1
