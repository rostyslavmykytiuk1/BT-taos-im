# Per-miner overlay for ./run_miner.sh -P miner-28
# Reworked v3: FEE-ONLY gate (rebate>=2bps, no spread gate) + FEE-based sleep (sleep fee>0, wake fee<-2bps, cap 40).
WALLET_NAME=sn79
HOTKEY_NAME=sn79-28
PM2_NAME=miner-28
AXON_PORT=8118
AGENT_PATH=/root/sn-79/agents
AGENT_NAME=PureMakerAgent
AGENT_PARAMS=lazy_load=1
